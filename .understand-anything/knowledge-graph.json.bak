    {
      "id": "domain:novel-upload-and-job-management",
      "type": "domain",
      "name": "小说上传与作业管理",
      "summary": "管理小说上传、转换作业的完整生命周期。支持创建作业（输入元数据和小说正文）、推进管线、阶段状态追踪、失败重试和作业删除。前端通过上传界面接收用户输入并自动创建作业，后端通过状态机驱动五阶段管线。",
      "tags": [
        "job-management",
        "upload",
        "pipeline-orchestration",
        "state-machine",
        "lifecycle"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "Job",
          "StageStatus",
          "JobState",
          "RetryRequest"
        ],
        "businessRules": [
          "作业创建后自动初始化五个阶段状态（均为pending）",
          "管线按序推进：分章→角色→场景→剧集→剧本",
          "每个阶段完成后作业进入awaiting_review状态，用户审核后继续",
          "重试时级联清理指定阶段之后的所有下游数据",
          "已完成的作业不可继续推进（返回400错误）"
        ],
        "crossDomainInteractions": [
          "创建作业后触发AI管线处理引擎的第一阶段（章节拆分）",
          "阶段完成后将数据传递给剧本数据管理域供用户编辑",
          "剧本导出域从最终阶段获取组装完成的剧本"
        ]
      }
    },
    {
      "id": "domain:ai-pipeline-processing",
      "type": "domain",
      "name": "AI管线处理引擎",
      "summary": "小说转剧本的核心AI处理流水线，包含五个串行阶段：章节拆分（正则优先+LLM兜底）、角色提取（并行+去重）、场景分析（并行识别节拍）、剧集结构化（组织场景为剧集）和剧本组装（人物表+改编说明）。各阶段通过Agent引擎调用GPT-4o执行AI推理。",
      "tags": [
        "ai-pipeline",
        "llm",
        "gpt-4o",
        "parallel-processing",
        "novel-conversion"
      ],
      "complexity": "complex",
      "domainMeta": {
        "entities": [
          "Chapter",
          "Character",
          "Scene",
          "SceneBeat",
          "Episode",
          "Script",
          "AgentEngine"
        ],
        "businessRules": [
          "五个阶段严格按序执行，每阶段依赖前一阶段输出",
          "章节拆分采用双策略：正则匹配优先（快速零成本），失败时LLM兜底",
          "角色提取和场景分析对每个章节并行调用Agent（受并发Semaphore限制）",
          "角色去重按姓名合并，聚合特征并保留最长描述",
          "场景节拍类型包括：dialogue、action、direction",
          "剧本编号格式：S01E01-01（剧集-场景-节拍）"
        ],
        "crossDomainInteractions": [
          "接收作业管理域发起的阶段执行请求",
          "产出数据供剧本数据管理域编辑",
          "最终阶段产出供剧本导出域下载"
        ]
      }
    },
    {
      "id": "domain:script-data-management",
      "type": "domain",
      "name": "剧本数据编辑与管理",
      "summary": "提供角色、场景、剧集数据的CRUD操作和AI辅助编辑功能。用户在管线阶段面板中查看AI生成的结果，可手动内联编辑每个字段，或通过自然语言指令让AI批量修改。修改后的数据保存到数据库并作为下一阶段的输入。",
      "tags": [
        "data-editing",
        "crud",
        "ai-assist",
        "character-editor",
        "scene-editor",
        "episode-editor"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "CharacterResponse",
          "SceneResponse",
          "EpisodeResponse",
          "AIAssistRequest",
          "CharacterUpdate",
          "SceneUpdate",
          "EpisodeUpdate"
        ],
        "businessRules": [
          "角色编辑支持内联修改名称、角色类型、特征、描述和关系",
          "场景编辑按章节分组展示，支持折叠展开和节拍级编辑",
          "剧集编辑允许修改标题、摘要和场景分配",
          "AI辅助编辑只修改用户指令中提到的部分，其他保持不变",
          "AI辅助编辑返回完整数据对象（不能只返回修改部分）",
          "编辑后的数据通过save API持久化到SQLite数据库"
        ],
        "crossDomainInteractions": [
          "编辑AI管线产出的阶段数据",
          "修改后的数据作为管线下一阶段的输入",
          "编辑结果影响最终剧本导出内容"
        ]
      }
    },
    {
      "id": "domain:script-export",
      "type": "domain",
      "name": "剧本导出与下载",
      "summary": "将管线生成的完整剧本数据导出为可下载文件。后端组装完整的ScriptResponse（含元数据、人物表、剧集列表和改编说明），前端进行客户端YAML序列化转换并通过Blob触发浏览器下载。",
      "tags": [
        "export",
        "download",
        "yaml",
        "script-output",
        "blob-download"
      ],
      "complexity": "simple",
      "domainMeta": {
        "entities": [
          "ScriptResponse",
          "ScriptMeta",
          "DramatisPersonae"
        ],
        "businessRules": [
          "剧本包含meta、dramatis_personae、episodes和adaptation_notes四个部分",
          "前端使用客户端toYaml序列化器生成YAML格式",
          "下载通过Blob + URL.createObjectURL触发浏览器下载",
          "剧本编号遵循S01E01-01格式（剧集-场景-节拍）"
        ],
        "crossDomainInteractions": [
          "从AI管线处理引擎获取组装完成的剧本数据",
          "剧本数据管理域的编辑结果直接影响导出内容"
        ]
      }
    },
    {
