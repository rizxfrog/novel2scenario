    "description": "AI 小说转剧本工具，将小说文本自动转换为结构化剧本（JSON/YAML 格式）。后端基于 FastAPI + Python 3.14，前端基于 React + Vite + TypeScript，使用 SQLite 存储，通过 OpenAI GPT-4o 驱动多阶段 AI 处理流水线。",
    "analyzedAt": "2026-07-13T00:00:00.000000+00:00",
    "gitCommitHash": "88ad0d2c035a122bf6621ca8d408da7a27063590"
  },
  "layers": [
    {
      "id": "layer:api",
      "name": "API 路由层",
      "description": "FastAPI HTTP 端点处理器，负责请求解析、路由分发和响应格式化，通过编排器委托业务逻辑，包含作业管理、角色/场景/剧集 CRUD 和 AI 辅助编辑接口",
      "nodeIds": [
        "file:backend/routes/ai_assist.py",
        "file:backend/routes/characters.py",
        "file:backend/routes/episodes.py",
        "file:backend/routes/jobs.py",
