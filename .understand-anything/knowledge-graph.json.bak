        "documentation",
        "api-reference",
        "rest-api",
        "endpoint-list"
      ],
      "complexity": "simple"
    },
    {
      "id": "entity:pipeline-view",
      "type": "entity",
      "name": "PipelineView（单页面流水线视图）",
      "summary": "前端架构重构核心概念：将原有的多页面路由替换为单一 PipelineView 页面，通过可折叠阶段面板内嵌编辑、侧边栏管理多 Job、底部状态栏显示进度的统一交互模式。",
      "tags": [
        "entity",
        "architecture-concept",
        "frontend"
      ],
      "complexity": "simple"
    },
    {
      "id": "entity:stage-status",
      "type": "entity",
      "name": "Stage Status（阶段状态追踪）",
      "summary": "新增的 stage_status 数据库表及配套函数，为每个 Job 的 5 个管线阶段提供独立的状态持久化（pending/running/awaiting_review/completed/failed），支持时间戳、输出摘要和错误信息记录。",
      "tags": [
        "entity",
        "database-schema",
        "state-tracking",
        "backend"
      ],
      "complexity": "simple"
    },
    {
      "id": "entity:retry-pipeline",
      "type": "entity",
      "name": "Checkpoint Retry（断点重试机制）",
      "summary": "管线断点重试机制：用户可从任意阶段重新运行，系统自动级联清理下游数据（_cleanup_downstream），重置受影响阶段状态为 pending，然后从目标阶段重新执行。支持选择性地重跑下游阶段。",
      "tags": [
        "entity",
        "retry-mechanism",
        "data-integrity",
        "backend"
      ],
      "complexity": "simple"
    },
    {
      "id": "entity:job-context",
      "type": "entity",
      "name": "JobContext（全局作业状态管理）",
      "summary": "前端全局状态管理方案：基于 React Context + useReducer 模式，管理作业列表、活跃作业、阶段状态、阶段数据、加载标志和错误信息的统一状态转换，提供 9 种 Action 类型和自动轮询机制。",
      "tags": [
        "entity",
        "state-management",
        "react-pattern",
        "frontend"
      ],
      "complexity": "simple"
    },
    {
      "id": "entity:2s-polling",
      "type": "entity",
      "name": "2秒轮询策略",
      "summary": "前端在管线阶段处于 running 状态时，每 2 秒通过 GET /api/jobs/{id}/stages 轮询阶段状态变化。当状态变为 awaiting_review 时停止轮询并自动展开阶段面板。",
      "tags": [
        "entity",
        "polling",
        "frontend",
        "real-time"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:pipeline-rebuild:single-page-view",
      "type": "claim",
      "name": "前端重构为单页面 PipelineView",
      "summary": "决策：完全重建前端为单一 PipelineView 页面，通过可折叠阶段面板内嵌编辑、侧边栏 Job 管理和状态栏进度显示，取代原有的多页面路由架构。选择方案 C（完全重建）而非方案 A 或 B。",
      "tags": [
        "claim",
        "architecture-decision",
        "frontend"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:pipeline-rebuild:stage-status-tracking",
      "type": "claim",
      "name": "新增 stage_status 表实现阶段级状态追踪",
      "summary": "决策：新增 stage_status 数据库表，为每个 Job 的 5 个阶段提供独立的状态持久化，包含时间戳、输出摘要和错误信息。相比仅在 jobs 表中维护单一 pipeline_stage 字段，此设计支持细粒度的阶段进度展示、断点重试和失败诊断。",
      "tags": [
        "claim",
        "database-design",
        "backend"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:pipeline-rebuild:checkpoint-retry-with-cleanup",
      "type": "claim",
      "name": "实现断点重试并级联清理下游数据",
      "summary": "决策：retry_pipeline 从指定阶段重新运行管线前，先通过 _cleanup_downstream 级联删除下游所有数据（按阶段序号映射确定清理边界），重置受影响阶段为 pending，确保数据一致性。",
      "tags": [
        "claim",
        "retry-mechanism",
        "data-integrity",
        "backend"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:pipeline-rebuild:context-reducer-state",
      "type": "claim",
      "name": "使用 React Context + useReducer 管理全局状态",
      "summary": "决策：前端采用 useReducer + Context 模式（而非 Redux 或 XState）管理全局作业状态，定义了 9 种 Action 类型，immutable 状态更新确保可预测性。",
      "tags": [
        "claim",
        "state-management",
        "frontend",
        "react"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:pipeline-rebuild:2s-polling-strategy",
      "type": "claim",
      "name": "运行中阶段采用 2 秒轮询策略",
      "summary": "决策：在前端管线处于 running 状态时，每 2 秒轮询 GET /api/jobs/{id}/stages 获取阶段状态。当阶段状态变为 awaiting_review 时自动停止轮询并展开面板显示数据。",
      "tags": [
        "claim",
        "polling",
        "frontend",
        "performance"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:brainstorm:full-rebuild-chosen",
      "type": "claim",
      "name": "头脑风暴选择方案 C（完全重建）",
      "summary": "在架构头脑风暴中比较了三种方案：A（重构 Layout + 新增 PipelineView）、B（最小改动，每页面嵌入流水线面板）、C（完全重建单一 PipelineView + 状态机驱动）。最终选择了方案 C，理由是架构最清晰、体验最统一、断点重试天然支持。",
      "tags": [
        "claim",
        "brainstorm",
        "architecture-decision",
        "design-exploration"
      ],
      "complexity": "simple"
    },
    {
      "id": "claim:design:api-spec-v2",
      "type": "claim",
      "name": "API 扩展规范 v2：新增 4 个端点",
      "summary": "管线重建方案扩展了后端 API，新增 GET /api/jobs（作业列表）、DELETE /api/jobs/{job_id}（删除作业）、GET /api/jobs/{job_id}/stages（阶段状态）、POST /api/jobs/{job_id}/retry（断点重试）共 4 个端点。",
      "tags": [
        "claim",
        "api-design",
        "backend",
        "specification"
      ],
      "complexity": "simple"
    }
  ],
