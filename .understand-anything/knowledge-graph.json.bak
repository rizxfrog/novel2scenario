        "file:backend/pipeline/__init__.py"
      ]
    },
    {
      "id": "layer:ai-agent",
      "name": "AI 引擎层",
      "description": "OpenAI GPT-4o Agent 引擎核心，提供异步客户端管理、带重试的智能体调用、鲁棒 JSON 解析（含截断修复）和并发并行执行能力，以及五阶段 LLM 提示词模板",
