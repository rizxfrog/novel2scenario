# OpenAI API Key（必填）
OPENAI_API_KEY=tp-c8p0kdutm6if9a3xm95rjqxafiyii8auad540dlb7aicfrof

# API 地址（必填，设置为你的 OpenAI 兼容接口地址）
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型名称（必填）
OPENAI_MODEL=mimo-v2.5-pro

# 自定义 Authorization header
# 某些国内接口不认默认的 "Bearer <key>" 格式
# 常见替代格式（根据你的接口文档选择）:
#   不传 Bearer 前缀:        tp-c8p0kd...
#   带 Bearer:               Bearer tp-c8p0kd...
#   X-API-Key header:        留空下面这行，改为设置环境变量 OPENAI_CUSTOM_HEADERS
OPENAI_AUTH_HEADER=tp-c8p0kdutm6if9a3xm95rjqxafiyii8auad540dlb7aicfrof

# 数据库路径（可选）
DATABASE_PATH=a:/map/novel2scenario.db

# 并行 Agent 数量（可选）
AGENT_CONCURRENCY=5
