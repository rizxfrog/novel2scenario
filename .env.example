# OpenAI API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here

# API 地址（必填，设置为你的 OpenAI 兼容接口地址）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（必填）
OPENAI_MODEL=gpt-4o

# 自定义 Authorization header 值（可选）
# 某些兼容接口不认默认的 "Bearer <key>" 格式
# 常见替代: 直接传 key 不加 Bearer 前缀
# 留空则使用标准 OpenAI 认证方式 (Bearer OPENAI_API_KEY)
# OPENAI_AUTH_HEADER=

# 完全自定义 headers（可选，JSON 格式）
# 用于需要非标准 header 名的接口，如 {"X-API-Key": "your-key"}
# 如果同时设置了 OPENAI_AUTH_HEADER，后者会覆盖 Authorization
# OPENAI_CUSTOM_HEADERS=

# 数据库路径（可选）
# DATABASE_PATH=novel2scenario.db

# 并行 Agent 数量（可选，默认 5）
# AGENT_CONCURRENCY=5
